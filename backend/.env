# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/amazon_intelligence
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amazon_intelligence
DB_USER=postgres
DB_PASSWORD=password

# AI Layer (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
